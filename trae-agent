#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
Trae Agent 包装器 - 智能定位并调用 trae-multi-agent skill

这个脚本可以放在任何项目中，自动查找并调用 skill
"""

import os
import sys
import subprocess
from pathlib import Path


def main():
    """主函数"""
    # 获取这个包装器脚本的位置
    wrapper_script = Path(__file__).resolve()
    skill_root = wrapper_script.parent
    
    # 验证 skill 目录是否正确
    dispatch_script = skill_root / 'scripts' / 'trae_agent_dispatch.py'
    
    if not dispatch_script.exists():
        print(f"❌ 错误：找不到调度脚本：{dispatch_script}", file=sys.stderr)
        print(f"   请确保这个脚本位于 skill 目录下", file=sys.stderr)
        sys.exit(1)
    
    # 转发所有参数
    try:
        result = subprocess.run(
            [sys.executable, str(dispatch_script)] + sys.argv[1:],
            cwd=Path.cwd()
        )
        sys.exit(result.returncode)
    except Exception as e:
        print(f"❌ 错误：调用 skill 失败：{e}", file=sys.stderr)
        sys.exit(1)


if __name__ == '__main__':
    main()
