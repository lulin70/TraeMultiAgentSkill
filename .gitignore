# === DevSquad V3.3 Git Ignore ===

# --- IDE & Editor ---
.idea/
.vscode/
*.swp
*.swo
*~
.trae/

# --- OS ---
.DS_Store
Thumbs.db

# --- Python ---
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# --- Test ---
.pytest_cache/
.coverage
htmlcov/

# --- Secrets & Credentials ---
.env
.env.*
*.key
*.pem
credentials.json

# --- Runtime Data ---
*.db
*.db-shm
*.db-wal
data/llm_cache/
data/tier2/corrections.json
data/tier2/user_preferences.json
data/registry/skills.json
data/progress/task_progress.json
data/progress/agent_loop.json

# --- Vibe Coding Runtime Data ---
scripts/vibe_coding/modules/*.json
scripts/vibe_coding/test_results/*.json
scripts/vibe_coding/multimodal/text_to_code/*.json
scripts/vibe_coding/multimodal/processing_history.json

# --- Runtime Context (auto-generated) ---
context/
data/context/

# --- Temp ---
tmp/
temp/
*.tmp
*.bak
*.patch

# --- Legacy / Unused (V2 remnants) ---
memory-bank/
prompts/
prompt_evolution/
plans/
install.sh
.git_disabled/
