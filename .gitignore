# === DevSquad V3.3 Git Ignore ===

# --- IDE & Editor ---
.idea/
.vscode/
*.swp
*.swo
*~
.trae/

# --- OS ---
.DS_Store
Thumbs.db

# --- Python ---
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# --- Test ---
.pytest_cache/
.coverage
htmlcov/

# --- Secrets & Credentials ---
.env
.env.*
*.key
*.pem
credentials.json

# --- Runtime Data (SQLite) ---
*.db
*.db-shm
*.db-wal

# --- Runtime Context (auto-generated) ---
context/
data/context/

# --- Temp ---
tmp/
temp/
*.tmp
*.bak
*.patch

# --- Legacy / Unused (V2 remnants) ---
memory-bank/
prompts/
prompt_evolution/
plans/
install.sh
